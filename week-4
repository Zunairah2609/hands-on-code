package com.cognizant.springlearn;

import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.boot.SpringApplication;
import org.springframework.boot.autoconfigure.SpringBootApplication;
import org.springframework.context.ApplicationContext;
import org.springframework.context.support.ClassPathXmlApplicationContext;

@SpringBootApplication
public class SpringLearnApplication {

    private static final Logger LOGGER = LoggerFactory.getLogger(SpringLearnApplication.class);

    public static void main(String[] args) {
        LOGGER.debug("Starting SpringLearnApplication main() method");
        SpringApplication.run(SpringLearnApplication.class, args);
        displayCountry();
        LOGGER.debug("SpringLearnApplication started successfully");
    }

    public static void displayCountry() {
        ApplicationContext context = new ClassPathXmlApplicationContext("country.xml");
        Country country = context.getBean("country", Country.class);
        LOGGER.debug("Country : {}", country.toString());
    }
}

--------------------------------------------------------------------
SME discussion notes
--------------------------------------------------------------------
- <bean> tag defines an object managed by the Spring container.
    - id: unique identifier used to retrieve the bean via getBean()
    - class: fully qualified class name Spring should instantiate
- <property> tag injects a value or reference into a bean's setter.
    - name: matches the property name (Spring calls setXxx())
    - value: literal value to inject (use "ref" attribute instead of "value"
      to inject a reference to another bean)
- ApplicationContext: central interface for accessing the Spring IoC container;
  provides bean retrieval, resource loading, and event publication.
- ClassPathXmlApplicationContext: implementation of ApplicationContext that
  loads bean definitions from an XML file located on the classpath.
- context.getBean("country", Country.class):
    1. Spring looks up the bean definition with id "country"
    2. Instantiates the class using the no-arg constructor
    3. Calls the corresponding setter for each <property> entry
    4. Returns the fully configured, cast Country object


